# ============ AdSathi configuration ============
# Demo mode: no external API is called, realistic mock data is returned.
# Set to false ONLY after you have completed Meta App Review + have real keys.
DRY_RUN=true

APP_NAME=AdSathi
BASE_URL=https://app.yourdomain.com
SECRET_KEY=change-this-to-a-long-random-string
DB_PATH=/data/adsathi.db

# ---- credits & pricing ----
SIGNUP_FREE_CREDITS=20
CREDITS_PER_IMAGE=2
CREDITS_PER_CAPTION_SET=1
CREDITS_PER_LAUNCH=5
BDT_PER_CREDIT=10

# ---- LLM (bilingual captions) ----
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# ---- image generation ----
IMAGE_PROVIDER=stub          # stub | openai
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-1

# ---- Meta / Facebook ----
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v21.0
META_OAUTH_REDIRECT=https://app.yourdomain.com/connect/facebook/callback
# Agency fallback (your own ad account used when a client hasn't connected theirs):
META_AGENCY_TOKEN=
META_AGENCY_AD_ACCOUNT_ID=
META_AGENCY_PAGE_ID=

# ---- payments (SSLCommerz: bKash / Nagad / cards) ----
PAYMENT_PROVIDER=sslcommerz
SSLCZ_STORE_ID=
SSLCZ_STORE_PASS=
SSLCZ_SANDBOX=true
